# App
APP_NAME=lingban-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-local

# Database
DATABASE_URL=postgresql+asyncpg://lingban:lingban@localhost:5432/lingban
DATABASE_POOL_SIZE=10

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI providers
# Leave empty for local smoke tests. The backend will use local fallback replies
# and rule-based memory extraction when these keys are not configured.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=qwen3.7-plus
OPENAI_CHAT_MAX_TOKENS=128
OPENAI_CHAT_DISABLE_REASONING=true
OPENAI_AUDIO_TRANSCRIPTION_MODEL=whisper-1
AI_CHAT_RESPONSE_CHAR_LIMIT=120
AI_LOCAL_STREAM_CHUNK_DELAY_MS=25
AI_MEMORY_RECALL_TIMEOUT_MS=800
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Push
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
JPUSH_API_URL=https://api.jpush.cn/v3/push
FCM_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=
FCM_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
FCM_SCOPE=https://www.googleapis.com/auth/firebase.messaging
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
APNS_USE_SANDBOX=true

# WeChat Pay
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# TTS
FISH_AUDIO_API_KEY=
FISH_AUDIO_BASE_URL=https://api.fish.audio
FISH_AUDIO_TTS_MODEL=s2-pro
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_TTS_FORMAT=mp3
FISH_AUDIO_ASR_LANGUAGE=
FISH_AUDIO_ASR_IGNORE_TIMESTAMPS=true

# JWT
JWT_SECRET_KEY=change-me-local
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

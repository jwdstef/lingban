# App
APP_NAME=lingban-backend
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-local

# Database
DATABASE_URL=postgresql+asyncpg://lingban:lingban@localhost:5432/lingban
DATABASE_POOL_SIZE=10

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI providers
# Leave empty for local smoke tests. The backend will use local fallback replies
# and rule-based memory extraction when these keys are not configured.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Push
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=

# TTS
FISH_AUDIO_API_KEY=

# JWT
JWT_SECRET_KEY=change-me-local
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
